---
import './Footer.scss';
---

<footer class="footer">
  <div class="footer-art" aria-hidden="true"></div>

  <div class="footer-content container">
    <div class="footer-top">
      <div>
        <span class="footer-eyebrow">Memories Travel Perú</span>
        <h2>Diseñamos viajes que se convierten en recuerdos.</h2>
      </div>

      <a 
        href="https://wa.me/51984544245" 
        target="_blank" 
        rel="noopener noreferrer" 
        class="footer-cta"
      >
        Diseñar mi viaje
      </a>
    </div>

    <div class="footer-grid">
      <div class="footer-col footer-brand">
        <a href="/" class="footer-logo" aria-label="Memories Travel Perú">
          <span class="footer-logo__mark">M</span>
          <span>
            MEMORIES
            <small>Travel Perú</small>
          </span>
        </a>

        <p>
          Comparta sus planes con nosotros y un especialista en viajes creará
          una propuesta personalizada según sus preferencias, tiempos y estilo
          de viaje.
        </p>

        <div class="socials">
          <a href="#" aria-label="Instagram">IG</a>
          <a href="#" aria-label="Facebook">FB</a>
          <a href="https://wa.me/51984544245" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp">WA</a>
        </div>
      </div>

      <div class="footer-col">
        <h4>Explorar</h4>
        <ul>
          <li><a href="/destinations">Destinos</a></li>
          <li><a href="/tours">Experiencias</a></li>
          <li><a href="/packages">Paquetes</a></li>
          <li><a href="/blogs">Blogs</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Empresa</h4>
        <ul>
          <li><a href="/about">Quiénes somos</a></li>
          <li><a href="/terms">Términos y condiciones</a></li>
          <li><a href="/privacy">Política de privacidad</a></li>
          <li><a href="/claims-book">Libro de reclamaciones</a></li>
        </ul>
      </div>

      <div class="footer-col footer-contact">
        <h4>Contacto</h4>
        <ul>
          <li>
            <span>Dirección</span>
            <a href="#">Av. El Sol 345, Cusco</a>
          </li>
          <li>
            <span>Teléfono</span>
            <a href="tel:+51984544245">+51 984 544 245</a>
          </li>
          <li>
            <span>WhatsApp</span>
            <a href="https://wa.me/51984544245" target="_blank" rel="noopener noreferrer">
              Cotizar viaje
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom__inner">
      <p>© 2026 Memories Travel Perú. Todos los derechos reservados.</p>
      <a href="/login">Admin</a>
    </div>
  </div>
</footer>