---
import type { Tour } from '../core/domain/models';
import './TourCard.scss';

interface Props {
  tour: Tour;
}

const { tour } = Astro.props;

const imageUrl =
  tour.imageUrl &&
  tour.imageUrl.trim() !== '' &&
  !tour.imageUrl.includes('---')
    ? tour.imageUrl
    : '/images/cusco.png';

const durationLabel = tour.durationNights
  ? `${tour.durationDays || 1} DÍAS`
  : `${tour.durationDays || 1} DÍAS`;

const locationLabel = tour.destinationName || tour.location || 'Perú';

const description =
  tour.shortDescription ||
  tour.description ||
  'Descubre una experiencia diseñada con detalle, comodidad y autenticidad.';

const priceLabel =
  tour.price && tour.price > 0
    ? `$ ${tour.price.toLocaleString()}`
    : 'A medida';

const detailUrl = `/tours/${tour.slug || tour.id}`;
---

<article class="tour-card">
  <a href={detailUrl} class="tour-card__image">
    <img src={imageUrl} alt={tour.title} />

    <span class="tour-card__badge">
      {durationLabel}
    </span>
  </a>

  <div class="tour-card__body">
    <span class="tour-card__location">
      {locationLabel.toUpperCase()}
    </span>

    <h3>
      <a href={detailUrl}>
        {tour.title}
      </a>
    </h3>

    <p>{description}</p>

    <div class="tour-card__footer">
      <div class="tour-card__price">
        <span>{tour.price && tour.price > 0 ? 'Desde' : 'Consultar'}</span>
        <strong>{priceLabel}</strong>
      </div>

      <a
        href={detailUrl}
        class="tour-card__arrow"
        aria-label={`Ver ${tour.title}`}
      >
        →
      </a>
    </div>
  </div>
</article>