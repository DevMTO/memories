---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { getToursUseCase } from '../../infrastructure/di';
import './_package-detail.scss';

const { id } = Astro.params;

const packages = await getToursUseCase.executePackages();

const pkg =
  id
    ? (await getToursUseCase.executePackageBySlug(id)) ||
      packages.find((item) => item.id === id) ||
      null
    : null;

if (!pkg) {
  return Astro.redirect('/packages');
}

const destinations = pkg.destinations ?? [];
const features = pkg.features ?? [];
const highlights = pkg.highlights ?? [];
const itinerary = pkg.itinerary ?? [];
const includes = pkg.includes ?? [];
const notIncludes = pkg.notIncludes ?? [];
const gallery = pkg.gallery ?? [];

const heroImage =
  pkg.imageUrl &&
  pkg.imageUrl.trim() !== '' &&
  !pkg.imageUrl.includes('---')
    ? pkg.imageUrl
    : '/images/cusco.png';

const durationDays = pkg.durationDays || 1;
const durationNights = pkg.durationNights || 0;

const durationText = durationNights
  ? `${durationDays} días / ${durationNights} noches`
  : `${durationDays} día${durationDays === 1 ? '' : 's'}`;

const heroDuration = durationNights
  ? `${durationDays} días / ${durationNights} noches`
  : `${durationDays} días`;

const destinationText =
  destinations.length > 0
    ? destinations.map((destination) => destination.name).slice(0, 4).join(', ')
    : 'Perú';

const whatsappMessage = `Hola, quiero información sobre el paquete: ${pkg.title}`;

const galleryImages =
  gallery.length > 0
    ? gallery
    : [
        '/images/cusco.png',
        '/images/hero.png',
        '/images/lima.png',
      ];
---

<Layout title={`${pkg.title} | Memories Travel Perú`} mainClass="package-detail-main">
  <!-- HERO -->
  <section class="package-hero" style={`background-image: url('${heroImage}');`}>
    <div class="package-hero__overlay"></div>

    <div class="container package-hero__content">
      <span class="package-hero__eyebrow">
        {heroDuration.toUpperCase()} {durationNights ? '(PRIVADO O GRUPO PEQUEÑO)' : '(EXPERIENCIA PERSONALIZADA)'}
      </span>

      <h1>{pkg.title}</h1>

      <p>
        {pkg.shortDescription ||
          'Experiencias curadas y exclusivas. Conectamos tu espíritu con la esencia viva y eterna del Perú.'}
      </p>
    </div>
  </section>

  <!-- INFO BAR -->
  <div class="container package-info-wrapper">
    <div class="package-info-bar">
      <div class="package-info-item">
        <span class="package-info-icon">♧</span>
        <span class="package-info-label">Duración</span>
        <span class="package-info-value">{durationText}</span>
      </div>

      <div class="package-info-item">
        <span class="package-info-icon">⌁</span>
        <span class="package-info-label">Destinos</span>
        <span class="package-info-value">{destinationText}</span>
      </div>

      <div class="package-info-item">
        <span class="package-info-icon">□</span>
        <span class="package-info-label">Servicio</span>
        <span class="package-info-value">{features[0] || 'Programa turístico'}</span>
      </div>

      <div class="package-info-item">
        <span class="package-info-icon">◇</span>
        <span class="package-info-label">Modalidad</span>
        <span class="package-info-value">
          {pkg.price && pkg.price > 0 ? `Desde $ ${pkg.price.toLocaleString()}` : 'A medida'}
        </span>
      </div>
    </div>
  </div>

  <!-- CONTENT -->
  <section class="package-detail-section">
    <div class="container package-detail-layout">
      <main class="package-main-content">
        <section class="package-copy-block">
          <h2>Sobre esta experiencia</h2>

          <p>
            {pkg.description ||
              'Sumérjase en una experiencia cuidadosamente diseñada para descubrir Perú con comodidad, autenticidad y acompañamiento experto.'}
          </p>

          {
            highlights.length > 0 && (
              <div class="package-mini-highlights">
                {highlights.slice(0, 4).map((highlight) => (
                  <span>{highlight}</span>
                ))}
              </div>
            )
          }
        </section>

        {
          itinerary.length > 0 && (
            <section class="package-itinerary-block">
              <h2>Itinerario Detallado</h2>

              <div class="package-timeline">
                {itinerary.slice(0, 6).map((day) => {
                  const dayMeals = day.meals ?? [];

                  return (
                    <article class="timeline-item">
                      <div class="timeline-marker">
                        {String(day.day).padStart(2, '0')}
                      </div>

                      <div class="timeline-content">
                        <h3>{day.title}</h3>
                        <p>{day.description}</p>

                        {
                          (day.accommodations || dayMeals.length > 0) && (
                            <div class="timeline-meta">
                              {day.accommodations && (
                                <span>⌂ {day.accommodations}</span>
                              )}

                              {dayMeals.length > 0 && (
                                <span>☕ {dayMeals.join(', ')}</span>
                              )}
                            </div>
                          )
                        }
                      </div>
                    </article>
                  );
                })}
              </div>
            </section>
          )
        }

        {
          includes.length > 0 || notIncludes.length > 0 ? (
            <section class="package-service-block">
              <h2>Información del servicio</h2>

              <div class="package-service-grid">
                {
                  includes.length > 0 && (
                    <article>
                      <h3>Incluye</h3>
                      <ul>
                        {includes.slice(0, 8).map((item) => (
                          <li>{item}</li>
                        ))}
                      </ul>
                    </article>
                  )
                }

                {
                  notIncludes.length > 0 && (
                    <article>
                      <h3>No incluye</h3>
                      <ul>
                        {notIncludes.slice(0, 8).map((item) => (
                          <li>{item}</li>
                        ))}
                      </ul>
                    </article>
                  )
                }
              </div>
            </section>
          ) : null
        }

        <section class="package-gallery-block">
          <h2>Highlights del Recorrido</h2>

          <div class="package-gallery">
            <img
              src={galleryImages[0] || heroImage}
              alt={pkg.title}
              class="package-gallery__large"
            />

            <div class="package-gallery__side">
              <img src={galleryImages[1] || '/images/hero.png'} alt={pkg.title} />
              <img src={galleryImages[2] || '/images/cusco.png'} alt={pkg.title} />
            </div>
          </div>
        </section>
      </main>

      <aside class="package-sidebar">
        <div class="booking-widget">
          <h3>Diseñe Su Viaje</h3>
          <p>Consultoría Gratuita Experta</p>

          <form class="booking-form">
            <div class="booking-field">
              <label>N° DE VIAJEROS</label>
              <input type="number" placeholder="2 adultos" />
            </div>

            <div class="booking-field">
              <label>FECHA DE VIAJE</label>
              <input type="text" placeholder="dd/mm/yy" />
            </div>

            <a
              href={`https://wa.me/51984544245?text=${encodeURIComponent(whatsappMessage)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="booking-btn"
            >
              Solicitar mi propuesta personalizada
            </a>

            <span>Sin cargos ocultos. Confirmación en 24h.</span>
          </form>
        </div>

        <div class="help-card">
          <div class="help-card__icon">□</div>

          <h3>¿Necesita ayuda?</h3>

          <p>
            Nuestros expertos en Cusco están listos para personalizar su itinerario.
          </p>

          <a
            href={`https://wa.me/51984544245?text=${encodeURIComponent(whatsappMessage)}`}
            target="_blank"
            rel="noopener noreferrer"
          >
            Contactar asesor
          </a>
        </div>
      </aside>
    </div>
  </section>

</Layout>