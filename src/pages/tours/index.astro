---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import TourCard from '../../components/TourCard.astro';
import { getToursUseCase } from '../../infrastructure/di';
import '../_tours.scss';

const allToursRaw = await getToursUseCase.executeAll();

const activeTours = (allToursRaw || []).filter((tour) => tour?.isActive !== false);

const destinations = Array.from(
  new Set(
    activeTours
      .map((tour) => tour.destinationName || tour.location || 'Perú')
      .filter(Boolean)
  )
);

const styles = [
  {
    label: 'Vacaciones',
    value: 'vacaciones viaje experiencia tour turistico turístico',
  },
  {
    label: 'Honeymoon',
    value: 'honeymoon pareja romantico romántico privado aguas calientes machu picchu',
  },
  {
    label: 'Family',
    value: 'familia family compartido cultural historia city tour',
  },
  {
    label: 'Tours',
    value: 'tour excursión excursion full day trekking aventura',
  },
];

const fallbackImages = [
  '/images/cusco.png',
  '/images/vinicunca.png',
  '/images/lima.png',
  '/images/ica.png',
  '/images/puno.png',
  '/images/arequipa.png',
];
---

<Layout title="Nuestros Tours | Memories Travel Perú" mainClass="tours-page">
  <!-- HERO -->
  <section class="tours-hero">
    <div class="tours-hero__overlay"></div>

    <div class="container tours-hero__content">
      <h1>NUESTROS TOURS</h1>
    </div>
  </section>

  <!-- CONTENT -->
  <section class="tours-section">
    <div class="container tours-layout">
      <!-- SIDEBAR -->
      <aside class="tours-sidebar">
        <div class="filters-box">
          <div class="filter-group">
            <h3>Travel Styles</h3>

            <div class="filter-options">
              {styles.map((style) => (
                <label class="filter-check">
                  <input
                    type="checkbox"
                    data-filter="style"
                    value={style.value}
                  />
                  <span>{style.label}</span>
                </label>
              ))}
            </div>
          </div>

          <div class="filter-group">
            <h3>Country</h3>

            <div class="filter-options">
              {destinations.slice(0, 8).map((destination) => (
                <label class="filter-check">
                  <input
                    type="checkbox"
                    data-filter="destination"
                    value={destination.toLowerCase()}
                  />
                  <span>{destination}</span>
                </label>
              ))}
            </div>
          </div>

          <div class="filter-group">
            <h3>Duration</h3>

            <div class="filter-options">
              <label class="filter-check">
                <input type="checkbox" data-filter="duration" value="1" />
                <span>Full Day</span>
              </label>

              <label class="filter-check">
                <input type="checkbox" data-filter="duration" value="2" />
                <span>2 días / 1 noche</span>
              </label>

              <label class="filter-check">
                <input type="checkbox" data-filter="durationRange" value="3" />
                <span>3 días a más</span>
              </label>
            </div>
          </div>

          <div class="filter-group">
            <h3>Price</h3>

            <div class="filter-price">
              <input
                id="priceRange"
                type="range"
                min="0"
                max="5000"
                step="100"
                value="5000"
              />
            </div>

            <div class="filter-price-labels">
              <span>$ 0</span>
              <span>$ 5000</span>
            </div>
          </div>

          <div class="filter-actions">
            <button type="button" class="filter-btn" id="clearFilters">
              Buscar
            </button>

            <button type="button" class="filter-reset" id="resetFilters">
              Limpiar filtros
            </button>
          </div>
        </div>
      </aside>

      <!-- GRID -->
      <div class="tours-main">
        {
          activeTours.length > 0 ? (
            <>
              <div class="tours-grid" id="toursGrid">
                {activeTours.map((tour, index) => {
                  const cleanImage =
                    tour.imageUrl &&
                    tour.imageUrl.trim() !== '' &&
                    !tour.imageUrl.includes('---')
                      ? tour.imageUrl
                      : fallbackImages[index % fallbackImages.length];

                  const searchableText = [
                    tour.title,
                    tour.description,
                    tour.shortDescription,
                    tour.destinationName,
                    tour.destinationSlug,
                    tour.location,
                    ...(tour.cities || []),
                    ...(tour.features || []),
                    ...(tour.highlights || []),
                  ]
                    .filter(Boolean)
                    .join(' ')
                    .toLowerCase();

                  return (
                    <div
                      class="tour-filter-item"
                      data-search={searchableText}
                      data-destination={(tour.destinationName || tour.location || '').toLowerCase()}
                      data-duration={String(tour.durationDays || '')}
                      data-price={String(tour.price || 0)}
                    >
                      <TourCard tour={{ ...tour, imageUrl: cleanImage }} />
                    </div>
                  );
                })}
              </div>

              <div class="tours-empty tours-empty--hidden" id="toursEmpty">
                <h3>No encontramos tours con esos filtros</h3>
                <p>
                  Prueba quitando algún filtro o solicita una propuesta personalizada.
                </p>
              </div>
            </>
          ) : (
            <div class="tours-empty">
              <h3>No hay tours disponibles</h3>
              <p>
                Revisa que tu mock data tenga tours activos o que el método
                executeAll() esté retornando información correctamente.
              </p>
            </div>
          )
        }
      </div>
    </div>
  </section>

</Layout>

<script>
  const filterInputs = document.querySelectorAll<HTMLInputElement>(
    'input[data-filter]'
  );

  const priceRange = document.querySelector<HTMLInputElement>('#priceRange');
  const tourItems = document.querySelectorAll<HTMLElement>('.tour-filter-item');
  const emptyState = document.querySelector<HTMLElement>('#toursEmpty');
  const clearButton = document.querySelector<HTMLButtonElement>('#clearFilters');
  const resetButton = document.querySelector<HTMLButtonElement>('#resetFilters');

  function normalizeText(value: string) {
    return value
      .toLowerCase()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '');
  }

  function getSelectedValues(filterType: string) {
    return Array.from(filterInputs)
      .filter((input) => input.dataset.filter === filterType && input.checked)
      .map((input) => normalizeText(input.value));
  }

  function textIncludesAny(text: string, values: string[]) {
    if (values.length === 0) return true;

    const normalizedText = normalizeText(text);

    return values.some((value) => {
      const words = value.split(' ').filter(Boolean);
      return words.some((word) => normalizedText.includes(word));
    });
  }

  function applyFilters() {
    const selectedStyles = getSelectedValues('style');
    const selectedDestinations = getSelectedValues('destination');
    const selectedDurations = getSelectedValues('duration');
    const selectedDurationRange = getSelectedValues('durationRange');
    const maxPrice = Number(priceRange?.value || 5000);

    let visibleCount = 0;

    tourItems.forEach((item) => {
      const searchText = item.dataset.search || '';
      const destination = normalizeText(item.dataset.destination || '');
      const duration = Number(item.dataset.duration || 0);
      const price = Number(item.dataset.price || 0);

      const matchesStyle = textIncludesAny(searchText, selectedStyles);

      const matchesDestination =
        selectedDestinations.length === 0 ||
        selectedDestinations.some((selected) => destination.includes(selected)) ||
        textIncludesAny(searchText, selectedDestinations);

      const matchesDuration =
        selectedDurations.length === 0 ||
        selectedDurations.includes(String(duration));

      const matchesDurationRange =
        selectedDurationRange.length === 0 ||
        duration >= Number(selectedDurationRange[0] || 3);

      const matchesPrice = price === 0 || price <= maxPrice;

      const isVisible =
        matchesStyle &&
        matchesDestination &&
        matchesDuration &&
        matchesDurationRange &&
        matchesPrice;

      item.classList.toggle('is-hidden', !isVisible);

      if (isVisible) visibleCount += 1;
    });

    emptyState?.classList.toggle('tours-empty--hidden', visibleCount > 0);
  }

  filterInputs.forEach((input) => {
    input.addEventListener('change', applyFilters);
  });

  priceRange?.addEventListener('input', applyFilters);

  clearButton?.addEventListener('click', applyFilters);

  resetButton?.addEventListener('click', () => {
    filterInputs.forEach((input) => {
      input.checked = false;
    });

    if (priceRange) {
      priceRange.value = '5000';
    }

    applyFilters();
  });

  applyFilters();
</script>