---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { getToursUseCase } from '../../infrastructure/di';
import './_detail.scss';

const { id } = Astro.params;

/*
  IMPORTANTE:
  Si tus enlaces son así:
  /tours/1
  usa executeById(id)

  Si tus enlaces son así:
  /tours/machu-picchu-full-day
  usa executeBySlug(id)

  Esta versión intenta primero por ID y luego por slug,
  para evitar errores si tus cards usan slug.
*/

const tour =
  id
    ? (await getToursUseCase.executeById(id)) ||
      (await getToursUseCase.executeBySlug(id))
    : null;

if (!tour) {
  return Astro.redirect('/tours');
}

const features = tour.features ?? [];
const highlights = tour.highlights ?? [];
const itinerary = tour.itinerary ?? [];
const includes = tour.includes ?? [];
const notIncludes = tour.notIncludes ?? [];
const whatToBring = tour.whatToBring ?? [];
const gallery = tour.gallery ?? [];

const heroImage =
  tour.imageUrl &&
  tour.imageUrl.trim() !== '' &&
  !tour.imageUrl.includes('---')
    ? tour.imageUrl
    : '/images/hero.jpg';

const durationDays = tour.durationDays || 1;

const durationText = tour.durationNights
  ? `${durationDays} días / ${tour.durationNights} noches`
  : `${durationDays} día${durationDays === 1 ? '' : 's'}`;

const destinationName = tour.destinationName || 'Perú';

const whatsappMessage = `Hola, quiero información sobre el tour: ${tour.title}`;
---

<Layout title={`${tour.title} | Memories Travel Perú`} mainClass="tour-detail-main">
  <section class="tour-detail-hero" style={`background-image: url('${heroImage}');`}>
    <div class="tour-detail-hero__overlay"></div>

    <div class="container tour-detail-hero__content">
      <span class="tour-detail-eyebrow">
        {destinationName}
      </span>

      <h1>{tour.title}</h1>

      <p>
        {tour.shortDescription ||
          'Una experiencia cuidadosamente diseñada para descubrir Perú con comodidad, cultura y acompañamiento profesional.'}
      </p>

      <div class="tour-detail-hero__actions">
        <a
          href={`https://wa.me/51984544245?text=${encodeURIComponent(whatsappMessage)}`}
          target="_blank"
          rel="noopener noreferrer"
          class="detail-btn detail-btn--primary"
        >
          Cotizar experiencia
        </a>

        <a href="/tours" class="detail-btn detail-btn--ghost">
          Ver más tours
        </a>
      </div>
    </div>
  </section>

  <div class="container info-bar-wrapper">
    <div class="info-bar">
      <div class="info-item">
        <span class="info-icon">01</span>
        <span class="info-label">Duración</span>
        <span class="info-val">{durationText}</span>
      </div>

      <div class="info-item">
        <span class="info-icon">02</span>
        <span class="info-label">Destino</span>
        <span class="info-val">{destinationName}</span>
      </div>

      <div class="info-item">
        <span class="info-icon">03</span>
        <span class="info-label">Modalidad</span>
        <span class="info-val">
          {features[0] || 'Servicio turístico'}
        </span>
      </div>

      <div class="info-item">
        <span class="info-icon">04</span>
        <span class="info-label">Acompañamiento</span>
        <span class="info-val">Guía profesional</span>
      </div>
    </div>
  </div>

  <section class="tour-detail-section">
    <div class="container tour-layout">
      <main class="tour-details">
        <section class="detail-block detail-block--intro">
          <span class="tour-detail-eyebrow tour-detail-eyebrow--dark">
            Sobre esta experiencia
          </span>

          <h2>{tour.title}</h2>

          <p class="tour-paragraph">
            {tour.description ||
              'Vive una experiencia cuidadosamente organizada para descubrir lo mejor de este destino.'}
          </p>

          {
            highlights.length > 0 && (
              <div class="highlight-pills">
                {highlights.slice(0, 6).map((highlight) => (
                  <span>{highlight}</span>
                ))}
              </div>
            )
          }
        </section>

        {
          itinerary.length > 0 && (
            <section class="detail-block">
              <div class="detail-heading">
                <span class="tour-detail-eyebrow tour-detail-eyebrow--dark">
                  Ruta día por día
                </span>
                <h2>Itinerario detallado</h2>
              </div>

              <div class="itinerary">
                {itinerary.map((day) => {
                  const dayIncludes = day.includes ?? [];
                  const dayMeals = day.meals ?? [];

                  return (
                    <article class="itinerary-day">
                      <div class="day-marker">
                        {String(day.day).padStart(2, '0')}
                      </div>

                      <div class="day-content">
                        <h3 class="day-title">{day.title}</h3>

                        <p class="day-desc">
                          {day.description}
                        </p>

                        {
                          (day.accommodations || dayMeals.length > 0) && (
                            <div class="day-meta">
                              {day.accommodations && (
                                <span>Alojamiento: {day.accommodations}</span>
                              )}

                              {dayMeals.length > 0 && (
                                <span>Comidas: {dayMeals.join(', ')}</span>
                              )}
                            </div>
                          )
                        }

                        {
                          dayIncludes.length > 0 && (
                            <div class="day-list">
                              <strong>Incluye este día</strong>

                              <ul>
                                {dayIncludes.slice(0, 6).map((item) => (
                                  <li>{item}</li>
                                ))}
                              </ul>
                            </div>
                          )
                        }
                      </div>
                    </article>
                  );
                })}
              </div>
            </section>
          )
        }

        {
          includes.length > 0 || notIncludes.length > 0 ? (
            <section class="detail-block">
              <div class="detail-heading">
                <span class="tour-detail-eyebrow tour-detail-eyebrow--dark">
                  Información del servicio
                </span>
                <h2>Incluye y no incluye</h2>
              </div>

              <div class="included-grid">
                {
                  includes.length > 0 && (
                    <article class="included-card included-card--yes">
                      <h3>Incluye</h3>

                      <ul>
                        {includes.map((item) => (
                          <li>{item}</li>
                        ))}
                      </ul>
                    </article>
                  )
                }

                {
                  notIncludes.length > 0 && (
                    <article class="included-card included-card--no">
                      <h3>No incluye</h3>

                      <ul>
                        {notIncludes.map((item) => (
                          <li>{item}</li>
                        ))}
                      </ul>
                    </article>
                  )
                }
              </div>
            </section>
          ) : null
        }

        {
          whatToBring.length > 0 && (
            <section class="detail-block">
              <div class="detail-heading">
                <span class="tour-detail-eyebrow tour-detail-eyebrow--dark">
                  Antes de viajar
                </span>
                <h2>Qué llevar</h2>
              </div>

              <div class="bring-grid">
                {whatToBring.map((item) => (
                  <span>{item}</span>
                ))}
              </div>
            </section>
          )
        }

        <section class="detail-block">
          <div class="detail-heading">
            <span class="tour-detail-eyebrow tour-detail-eyebrow--dark">
              Galería
            </span>
            <h2>Momentos del recorrido</h2>
          </div>

          <div class="highlights-grid">
            <img
              src={gallery[0] || heroImage}
              alt={tour.title}
              class="hl-img-large"
            />

            <div class="hl-side">
              <img
                src={gallery[1] || '/images/tour1.jpg'}
                alt={tour.title}
              />

              <img
                src={gallery[2] || '/images/tour2.jpg'}
                alt={tour.title}
              />
            </div>
          </div>
        </section>
      </main>

      <aside class="tour-sidebar">
        <div class="booking-widget">
          <span class="widget-eyebrow">Diseña tu viaje</span>

          <h3 class="widget-title">
            Solicita una propuesta personalizada
          </h3>

          <p class="widget-desc">
            Cuéntanos tus fechas, número de viajeros y preferencias. Nuestro
            equipo te ayudará a adaptar esta experiencia.
          </p>

          <div class="widget-summary">
            <div>
              <span>Duración</span>
              <strong>{durationText}</strong>
            </div>

            <div>
              <span>Destino</span>
              <strong>{destinationName}</strong>
            </div>

            <div>
              <span>Tipo</span>
              <strong>{features[0] || 'Tour guiado'}</strong>
            </div>
          </div>

          <a
            href={`https://wa.me/51984544245?text=${encodeURIComponent(whatsappMessage)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-widget"
          >
            Cotizar por WhatsApp
          </a>

          <a href="/tours" class="btn-widget btn-widget--outline">
            Ver otros tours
          </a>

          <p class="widget-note">
            Atención personalizada. Te ayudamos a revisar disponibilidad,
            horarios, ingresos y logística del recorrido.
          </p>
        </div>
      </aside>
    </div>
  </section>
</Layout>