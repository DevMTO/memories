---
// ✅ This page fetches from Firebase, so it needs to run at request time
// not at build time. Set prerender = false for hybrid rendering.
export const prerender = false;

import Layout from "../layouts/Layout.astro";
import TourCard from "../components/TourCard.astro";
import { getToursUseCase } from "../infrastructure/di";
import "./_home.scss";

// This will run at request time when output = 'hybrid'
const featuredTours = await getToursUseCase.executeFeatured();
const destinations = await getToursUseCase.executeDestinations();
---

<Layout title="Home" mainClass="home-main">
  <!-- Hero Section -->
  <section class="hero" style={`background-image: url('/images/hero.jpg');`}>
    <div class="overlay"></div>
    <div class="container hero-content text-center reveal-up">
      <span class="subtitle">AGENCIA DE VIAJES / TOUR OPERADOR</span>
      <h1 class="hero-title">MEMORIES</h1>
      <p class="hero-desc">Travel Perú</p>
      <p class="hero-subdesc">
        EXPERIENCIAS CURADAS Y EXCLUSIVAS. CONECTAMOS TU ESPÍRITU CON LA ESENCIA
        VIVA Y ETERNA DEL PERÚ.
      </p>
      <a href="/login" class="btn btn-primary btn-rounded hero-cta"
        >DESIGN TRIP</a
      >
    </div>
  </section>

  <!-- Transformative Journeys Section -->
  <section class="transformative-section reveal-up">
    <div class="container transformative-grid">
      <div class="text-content">
        <span class="subtitle">EXPERIENCIAS EXCLUSIVAS</span>
        <h2>Viajes Que <br /><span class="italic-title">Transforman</span></h2>
        <p class="description">
          Somos Arquitectos De Experiencias. No Solo Vendemos Tours, Diseñamos
          Momentos Que Se Convierten En Recuerdos Imborrables.
        </p>
        <div class="stats-grid">
          <div>
            <h4 class="text-accent">Nuestros Tours</h4>
            <p class="stat-desc">Guías Nativos Certificados</p>
          </div>
          <div>
            <h4 class="text-accent">Sin Límites</h4>
            <p class="stat-desc">Personalización Total</p>
          </div>
        </div>
        <a href="/tours" class="text-accent cta-link">VER MÁS DESTINOS →</a>
      </div>
      <div class="img-content">
        <img src="/images/tour1.jpg" alt="Viajes Que Transforman" class="img-reveal" />
      </div>
    </div>
  </section>

  <!-- Featured Tours -->
  <section class="section section--alt reveal-up">
    <div class="container">
      <div class="section-header text-center">
        <span class="subtitle text-primary">EXPERIENCIAS EXCLUSIVAS</span>
        <h2>Nuestros Tours</h2>
        <p>
          Itinerarios Diseñados Meticulosamente Para Viajeros Que Buscan
          Autenticidad.
        </p>
      </div>
      <div class="tours-grid">
        {featuredTours.map((tour) => <TourCard tour={tour} />)}
      </div>
    </div>
  </section>

  <!-- Destinations -->
  <section class="section reveal-up">
    <div class="container">
      <div class="dest-header">
        <div>
          <span class="subtitle text-primary">COLECCIÓN 2026</span>
          <h2>Destinos <span class="dest-title-italic">Icónicos</span></h2>
        </div>
        <a href="/destinations" class="dest-link">VER MÁS DESTINOS</a>
      </div>
      <div class="dest-grid">
        <div class="dest-item main-dest">
          <img
            src={destinations[0]?.imageUrl || "/images/hero.jpg"}
            alt={destinations[0]?.name}
          />
          <h3>{destinations[0]?.name}</h3>
        </div>
        <div class="dest-side">
          <div class="dest-item top-dest">
            <img
              src={destinations[1]?.imageUrl || "/images/hero.jpg"}
              alt={destinations[1]?.name}
            />
            <h3>{destinations[1]?.name}</h3>
          </div>
          <div class="dest-bottom-row">
            <div class="dest-item">
              <img
                src={destinations[2]?.imageUrl || "/images/hero.jpg"}
                alt={destinations[2]?.name}
              />
              <h3>{destinations[2]?.name}</h3>
            </div>
            <div class="dest-item">
              <img
                src={destinations[3]?.imageUrl || "/images/hero.jpg"}
                alt={destinations[3]?.name}
              />
              <h3>{destinations[3]?.name}</h3>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Simple Reveal Animation on Scroll
  const revealCallback = (entries: IntersectionObserverEntry[], observer: IntersectionObserver) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-revealed');
        observer.unobserve(entry.target);
      }
    });
  };

  const observerOptions = {
    threshold: 0.15,
    rootMargin: '0px 0px -50px 0px'
  };

  const revealObserver = new IntersectionObserver(revealCallback, observerOptions);
  
  document.querySelectorAll('.reveal-up, .img-reveal').forEach(el => {
    revealObserver.observe(el);
  });

  // Sticky Header logic
  const header = document.querySelector('.header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      header?.classList.add('is-scrolled');
    } else {
      header?.classList.remove('is-scrolled');
    }
  });
</script>

<style is:global>
  /* Reveal Animations base styles */
  .reveal-up {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease-out, transform 0.8s ease-out;
  }

  .reveal-up.is-revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .img-reveal {
    opacity: 0;
    transform: scale(0.95);
    transition: opacity 1s ease-out, transform 1s ease-out;
  }

  .img-reveal.is-revealed {
    opacity: 1;
    transform: scale(1);
  }

  /* Smooth scroll behavior */
  html {
    scroll-behavior: smooth;
  }
</style>
