---
// ✅ This page fetches from Firebase, so it needs to run at request time
export const prerender = false;

import Layout from "../layouts/Layout.astro";
import TourCard from "../components/TourCard.astro";
import { getToursUseCase } from "../infrastructure/di";
import "./_home.scss";

const featuredTours = await getToursUseCase.executeFeatured();
const destinations = await getToursUseCase.executeDestinations();

const safeDestinations = destinations?.slice(0, 4) || [];
const safeFeaturedTours = featuredTours?.slice(0, 6) || [];
---

<Layout title="Memories Travel Perú | Agencia de viajes en Perú" mainClass="home-main">
  <!-- HERO -->
  <section class="hero" style={`background-image: url('/images/hero.jpg');`}>
    <div class="hero__overlay"></div>
    <div class="hero__noise"></div>

    <div class="container hero__content reveal-up">
      <div class="hero__copy">
        <span class="eyebrow">Agencia de viajes / Tour operador en Perú</span>

        <h1>
          Viajes que se sienten,  
          <span>recuerdos que permanecen.</span>
        </h1>

        <p class="hero__description">
          Diseñamos experiencias auténticas por Perú, conectando cultura,
          naturaleza y aventura en itinerarios creados para viajeros que buscan
          algo más que un tour.
        </p>

        <div class="hero__actions">
          <a href="/tours" class="btn btn--primary">Explorar experiencias</a>
          <a href="/destinations" class="btn btn--ghost">Ver destinos</a>
        </div>

        <div class="hero__trust">
          <div>
            <strong>+10</strong>
            <span>experiencias destacadas</span>
          </div>
          <div>
            <strong>Perú</strong>
            <span>Costa, Andes y cultura viva</span>
          </div>
          <div>
            <strong>24/7</strong>
            <span>acompañamiento en ruta</span>
          </div>
        </div>
      </div>

      <div class="hero__card">
        <span class="hero__card-label">Experiencia recomendada</span>
        <h3>Machu Picchu & Valle Sagrado</h3>
        <p>
          Historia, paisajes andinos, tren turístico y una visita guiada a una
          de las maravillas del mundo.
        </p>
        <a href="/tours" class="hero__card-link">Diseñar mi viaje →</a>
      </div>
    </div>

    <div class="hero__scroll">
      <span>Descubre Perú</span>
    </div>
  </section>

  <!-- BRAND INTRO -->
  <section class="intro-section reveal-up">
    <div class="container intro-grid">
      <div class="intro-media">
        <img src="/images/tour1.jpg" alt="Experiencias de viaje en Perú" />
        <div class="intro-badge">
          <strong>Memories</strong>
          <span>Travel Perú</span>
        </div>
      </div>

      <div class="intro-content">
        <span class="eyebrow dark">Experiencias diseñadas con intención</span>
        <h2>
          No organizamos simples viajes,  
          <span>creamos memorias con sentido.</span>
        </h2>
        <p>
          En Memories Travel Perú combinamos planificación, atención cercana y
          conocimiento local para crear recorridos auténticos por los destinos
          más icónicos del país.
        </p>

        <div class="benefits-grid">
          <article>
            <span>01</span>
            <h3>Itinerarios a medida</h3>
            <p>Programas flexibles según ritmo, estilo de viaje y destino.</p>
          </article>

          <article>
            <span>02</span>
            <h3>Operación confiable</h3>
            <p>Coordinación antes, durante y después de cada experiencia.</p>
          </article>

          <article>
            <span>03</span>
            <h3>Guías profesionales</h3>
            <p>Acompañamiento experto para conectar con la historia y cultura.</p>
          </article>

          <article>
            <span>04</span>
            <h3>Destinos icónicos</h3>
            <p>Cusco, Machu Picchu, Lima, Puno, Arequipa, Nazca y más.</p>
          </article>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURED TOURS -->
  <section class="section section--soft reveal-up">
    <div class="container">
      <div class="section-header">
        <div>
          <span class="eyebrow dark">Experiencias destacadas</span>
          <h2>Tours para empezar tu historia en Perú</h2>
        </div>
        <p>
          Seleccionamos recorridos que combinan paisajes, cultura, aventura y
          logística bien organizada para que el viaje fluya desde el primer día.
        </p>
      </div>

      <div class="tours-grid">
        {safeFeaturedTours.map((tour) => <TourCard tour={tour} />)}
      </div>

      <div class="section-action">
        <a href="/tours" class="btn btn--dark">Ver todos los tours</a>
      </div>
    </div>
  </section>

  <!-- DESTINATIONS -->
  <section class="destinations-section reveal-up">
    <div class="container">
      <div class="dest-header">
        <div>
          <span class="eyebrow dark">Colección Perú</span>
          <h2>Destinos que despiertan recuerdos</h2>
        </div>
        <a href="/destinations" class="link-arrow">Ver más destinos →</a>
      </div>

      <div class="dest-grid">
        {
          safeDestinations.map((destination, index) => (
            <a
              href={`/destinations/${destination.slug}`}
              class={`dest-card ${index === 0 ? "dest-card--large" : ""}`}
            >
              <img
                src={destination.imageUrl || "/images/hero.jpg"}
                alt={destination.name}
              />
              <div class="dest-card__content">
                <span>Explorar destino</span>
                <h3>{destination.name}</h3>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- EXPERIENCE STRIP -->
  <section class="experience-strip reveal-up">
    <div class="container experience-strip__inner">
      <div>
        <span class="eyebrow">Viajes con esencia local</span>
        <h2>Perú se vive mejor cuando cada detalle está pensado.</h2>
      </div>

      <div class="experience-steps">
        <article>
          <span>Planifica</span>
          <p>Cuéntanos qué tipo de viaje imaginas.</p>
        </article>
        <article>
          <span>Personaliza</span>
          <p>Ajustamos rutas, tiempos, hoteles y experiencias.</p>
        </article>
        <article>
          <span>Viaja</span>
          <p>Disfruta con soporte y coordinación en destino.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="final-cta reveal-up">
    <div class="container final-cta__box">
      <span class="eyebrow dark">Tu próxima memoria empieza aquí</span>
      <h2>Diseñemos juntos tu viaje por Perú.</h2>
      <p>
        Desde una escapada a Machu Picchu hasta un recorrido completo por costa,
        sierra y lago Titicaca. Creamos una experiencia pensada para ti.
      </p>
      <div class="final-cta__actions">
        <a href="/login" class="btn btn--primary">Diseñar mi viaje</a>
        <a href="/tours" class="btn btn--outline">Ver experiencias</a>
      </div>
    </div>
  </section>
</Layout>

<script>
  const revealCallback = (
    entries: IntersectionObserverEntry[],
    observer: IntersectionObserver
  ) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add("is-revealed");
        observer.unobserve(entry.target);
      }
    });
  };

  const revealObserver = new IntersectionObserver(revealCallback, {
    threshold: 0.15,
    rootMargin: "0px 0px -50px 0px",
  });

  document.querySelectorAll(".reveal-up").forEach((el) => {
    revealObserver.observe(el);
  });

  const header = document.querySelector(".header");

  window.addEventListener("scroll", () => {
    if (window.scrollY > 50) {
      header?.classList.add("is-scrolled");
    } else {
      header?.classList.remove("is-scrolled");
    }
  });
</script>

<style is:global>
  html {
    scroll-behavior: smooth;
  }

  .reveal-up {
    opacity: 0;
    transform: translateY(34px);
    transition:
      opacity 0.8s ease,
      transform 0.8s ease;
  }

  .reveal-up.is-revealed {
    opacity: 1;
    transform: translateY(0);
  }
</style>